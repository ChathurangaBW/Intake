INTAKE_ENV=development
INTAKE_DATABASE_URL=postgresql://intake:intake@localhost:5432/intake

INTAKE_OBJECT_STORE_ENDPOINT=http://localhost:9000
INTAKE_OBJECT_STORE_BUCKET=intake-evidence
INTAKE_OBJECT_STORE_ACCESS_KEY=intake
INTAKE_OBJECT_STORE_SECRET_KEY=intake-dev-password
INTAKE_OBJECT_STORE_REGION=us-east-1
INTAKE_OBJECT_STORE_SECURE=false

INTAKE_OPA_URL=http://localhost:8181/v1/data/intake/decision
INTAKE_DEFAULT_NETWORK_POLICY=deny_all

INTAKE_WORKER_STATIC_IMAGE=intake/static-worker:dev
INTAKE_WORKER_DYNAMIC_BACKEND=manual-vm
INTAKE_MAXIMUM_TOOL_RUNTIME_SECONDS=1800
INTAKE_MAXIMUM_AGENT_TURNS=12
INTAKE_MAXIMUM_TOOL_CALLS=30
INTAKE_MAXIMUM_SUBAGENT_DEPTH=1
INTAKE_MAXIMUM_COST_USD=2.0

INTAKE_ALLOW_UNRESTRICTED_SHELL=false
INTAKE_ALLOW_DYNAMIC_EXECUTION_WITHOUT_APPROVAL=false

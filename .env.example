INTAKE_ENV=development
INTAKE_DATABASE_URL=postgresql+psycopg://intake:intake@localhost:5432/intake
INTAKE_DATABASE_POOL_SIZE=10
INTAKE_DATABASE_MAX_OVERFLOW=20

INTAKE_OBJECT_STORE_ENDPOINT=http://localhost:9000
INTAKE_OBJECT_STORE_BUCKET=intake-evidence
INTAKE_OBJECT_STORE_ACCESS_KEY=intake
INTAKE_OBJECT_STORE_SECRET_KEY=intake-dev-password
INTAKE_OBJECT_STORE_REGION=us-east-1
INTAKE_OBJECT_STORE_SECURE=false

INTAKE_OPA_URL=http://localhost:8181/v1/data/intake/decision
INTAKE_OPA_HEALTH_URL=http://localhost:8181/health
INTAKE_DEFAULT_NETWORK_POLICY=deny_all

# Legacy single admin key. Leave blank only for disposable localhost development.
INTAKE_API_KEY=
# Role-aware key mapping. In Compose, export this value as INTAKE_API_KEYS_JSON.
# INTAKE_API_KEYS={"viewer-secret":"viewer","operator-secret":"operator","approver-secret":"approver","admin-secret":"admin"}
INTAKE_API_KEYS={}
INTAKE_ENABLE_WEB_UI=true
INTAKE_ALLOWED_ORIGINS=[]
INTAKE_TRUSTED_HOSTS=["127.0.0.1","localhost","testserver"]
INTAKE_MAXIMUM_REQUEST_BYTES=16777216
INTAKE_MAXIMUM_UPLOAD_BYTES=67108864
INTAKE_READINESS_TIMEOUT_SECONDS=3
INTAKE_STRUCTURED_LOGGING=true
INTAKE_METRICS_ENABLED=true
INTAKE_ENABLE_INLINE_TOOL_EXECUTION=false

INTAKE_WORKER_STATIC_IMAGE=intake/static-worker:dev
INTAKE_WORKER_DYNAMIC_BACKEND=manual-vm
INTAKE_WORKER_POLL_INTERVAL_SECONDS=1
INTAKE_JOB_LEASE_SECONDS=900
INTAKE_ENABLE_EXTERNAL_STATIC_TOOLS=false
INTAKE_RIZIN_PATH=rizin
INTAKE_GHIDRA_ANALYZE_HEADLESS_PATH=analyzeHeadless
INTAKE_GHIDRA_PROJECT_ROOT=/tmp/intake-ghidra
INTAKE_EXTERNAL_TOOL_OUTPUT_LIMIT_BYTES=262144

INTAKE_MAXIMUM_TOOL_RUNTIME_SECONDS=1800
INTAKE_MAXIMUM_AGENT_TURNS=12
INTAKE_MAXIMUM_TOOL_CALLS=30
INTAKE_MAXIMUM_SUBAGENT_DEPTH=1
INTAKE_MAXIMUM_COST_USD=2.0

INTAKE_ALLOW_UNRESTRICTED_SHELL=false
INTAKE_ALLOW_DYNAMIC_EXECUTION_WITHOUT_APPROVAL=false

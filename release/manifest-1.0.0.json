{
  "name": "Intake",
  "version": "1.0.0",
  "status": "stable local-first release",
  "repository": "https://github.com/ChathurangaBW/Intake",
  "container": "ghcr.io/chathurangabw/intake",
  "python_package": "intake-security",
  "entrypoints": {
    "api": "intake.api:app",
    "cli": "intake",
    "worker": "intake-worker"
  },
  "runtime_services": [
    "FastAPI",
    "PostgreSQL",
    "OPA",
    "MinIO"
  ],
  "operator_surfaces": [
    "Browser operator console",
    "OpenAPI docs",
    "Typer CLI",
    "Python SDK",
    "HTTP request collection",
    "Operations control plane"
  ],
  "release_gates": [
    "ruff lint",
    "unit tests",
    "contract tests",
    "security checks",
    "compose smoke test",
    "docker image build",
    "operator console contract test",
    "readiness diagnostics",
    "evidence verification",
    "audit export"
  ],
  "blocked_defaults": [
    "unrestricted shell execution",
    "exploit automation",
    "evasion",
    "persistence",
    "destructive actions",
    "unscoped active network operations",
    "autonomous dynamic execution"
  ],
  "release_commit_expected": "main",
  "tag": "v1.0.0"
}
